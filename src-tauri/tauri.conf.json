{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SDP Catcher",
  "version": "1.0.0",
  "identifier": "com.allan.sdp-catcher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SDP Catcher",
        "width": 1050,
        "height": 600,
        "minWidth": 800,
        "minHeight": 600,
        "theme": "Dark",
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Allan Le Guyader",
    "windows": {
      "wix": {
        "language": "fr-FR"
      }
    }
  }
}
